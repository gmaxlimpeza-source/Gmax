rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Products Rules
    match /products/{productId} {
      allow read: if isSignedIn();
      
      function isValidProduct(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.barcode is string && data.barcode.size() > 0 && data.barcode.size() <= 64 &&
               data.price is number && data.price >= 0 &&
               data.stock is number &&
               (!('minStock' in data) || data.minStock is number);
      }

      allow create: if isSignedIn() && isValidProduct(incoming());
      allow update: if isSignedIn() && (
        isValidProduct(incoming()) ||
        (incoming().diff(existing()).affectedKeys().hasAll(['stock']) &&
         incoming().diff(existing()).affectedKeys().size() == 1 &&
         incoming().stock is number)
      );
      allow delete: if isSignedIn();
    }

    // Sales Rules
    match /sales/{saleId} {
      allow read: if isSignedIn();

      function isValidSale(data) {
        return data.items is list && data.items.size() > 0 &&
               data.total is number && data.total >= 0 &&
               (data.paymentMethod == 'cash' || 
                data.paymentMethod == 'card' || 
                data.paymentMethod == 'pix' || 
                data.paymentMethod == 'on_account' || 
                data.paymentMethod == 'multiple');
      }

      function isValidSaleUpdate(data) {
        return (
          // Action: Settle Sale
          (incoming().onAccountStatus == 'paid' &&
           incoming().settledAt == request.time &&
           incoming().total == existing().total) ||
          // Action: Void Sale
          (incoming().isVoided == true &&
           incoming().voidedAt == request.time &&
           incoming().total == existing().total)
        );
      }

      allow create: if isSignedIn() && isValidSale(incoming());
      allow update: if isSignedIn() && isValidSaleUpdate(incoming());
      allow delete: if isSignedIn();
    }
  }
}
